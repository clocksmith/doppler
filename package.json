{
  "name": "doppler-gpu",
  "version": "0.2.1",
  "description": "Browser-native WebGPU inference engine for local intent and inference loops",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "bin": {
    "doppler": "src/cli/doppler-cli.js",
    "doppler-gpu": "src/cli/doppler-quickstart.js",
    "doppler-serve": "src/cli/doppler-serve.js"
  },
  "scripts": {
    "quickstart": "node src/cli/doppler-quickstart.js",
    "serve": "node src/cli/doppler-serve.js",
    "cli": "node src/cli/doppler-cli.js",
    "convert": "node src/cli/doppler-cli.js convert",
    "manifest-refresh": "node tools/refresh-converted-manifest.js",
    "debug": "node src/cli/doppler-cli.js debug",
    "bench": "node src/cli/doppler-cli.js bench",
    "lean:check": "./lean/check.sh",
    "lean:execution-contract": "node tools/lean-execution-contract.js",
    "lean:execution-contract:sweep": "node tools/lean-execution-contract-sweep.js",
    "lean:execution-contract:configs": "node tools/lean-execution-contract-config-sweep.js",
    "ci:lean:execution-contract": "node tools/lean-execution-contract-sweep.js --root models",
    "ci:lean:execution-contract:configs": "node tools/lean-execution-contract-config-sweep.js --config-root src/config/conversion --manifest-root models --require-manifest-match",
    "contracts:check": "node tools/check-contract-artifacts.js",
    "contracts:summary": "node tools/check-contract-artifacts.js --json",
    "contracts:check:lean": "node tools/check-contract-artifacts.js --with-lean",
    "contracts:summary:lean": "node tools/check-contract-artifacts.js --json --with-lean",
    "ci:contracts:check": "node tools/check-contract-artifacts.js --with-lean --lean-require-manifest-match",
    "reports:convert:summary": "node tools/summarize-conversion-reports.js",
    "bench:chart": "node ./benchmarks/vendors/compare-chart.js",
    "bench:chart:readme": "node ./benchmarks/vendors/compare-chart.js --scenario readme-evidence",
    "bench:architecture:chart": "node ./benchmarks/vendors/generate-architecture-overview-svg.js",
    "bench:tjs:stage": "node tools/stage-tjs-model.js",
    "ci:diffusion:contract": "node tools/ci-diffusion-contract-gates.js",
    "ci:diffusion:contract:list": "node tools/ci-diffusion-contract-gates.js --list",
    "ci:training:contract": "node tools/ci-training-contract-gates.js",
    "ci:training:contract:list": "node tools/ci-training-contract-gates.js --list",
    "training:contract:delta": "node tools/emit-training-contract-delta.js",
    "training:workloads:verify": "node tools/verify-training-workload-packs.js --registry src/experimental/training/workload-packs/registry.json",
    "training:report-ids:publish": "node tools/publish-training-report-ids.js --registry src/experimental/training/workload-packs/registry.json",
    "distill:studio:mvp": "node tools/distill-studio-mvp.js",
    "distill:quality-gate": "node tools/distill-studio-quality-gate.js",
    "p2p:observability": "node tools/p2p-delivery-observability.js",
    "p2p:drill": "node tools/p2p-resilience-drill.js",
    "test": "npm run test:unit",
    "typecheck:source-runtime": "tsc -p tsconfig.source-runtime.json --noEmit",
    "test:unit": "node tools/run-node-tests.js --suite unit",
    "test:gpu": "node tools/run-node-tests.js --suite gpu",
    "test:coverage": "node tools/run-node-coverage.js",
    "test:coverage:report": "node tools/run-node-coverage.js --no-threshold",
    "test:gpu:browser": "node src/cli/doppler-cli.js verify --config '{\"request\":{\"workload\":\"kernels\"},\"run\":{\"surface\":\"browser\",\"browser\":{\"opfsCache\":false,\"headless\":true,\"channel\":\"chromium\",\"browserArgs\":[\"--use-angle=swiftshader\",\"--disable-vulkan-surface\"],\"console\":true}}}'",
    "agents:verify": "node tools/verify-agent-parity.js",
    "agents:freshness": "node tools/verify-agent-freshness.js",
    "agents:freshness:strict": "node tools/verify-agent-freshness.js --strict",
    "conflicts:check": "node tools/check-merge-markers.js",
    "imports:check:browser": "node tools/check-browser-import-graph.js",
    "api:docs:sync": "node tools/sync-api-docs.js",
    "api:docs:check": "node tools/sync-api-docs.js --check",
    "public:boundaries:check": "node tools/check-public-boundaries.js",
    "verify:model": "node src/cli/doppler-cli.js verify",
    "quickstart:sync": "node tools/sync-quickstart-registry.js",
    "quickstart:check": "node tools/sync-quickstart-registry.js --check",
    "execution-graph:patch": "node tools/patch-execution-graph.js",
    "onboarding:check": "node tools/onboarding-tooling.js check",
    "onboarding:check:strict": "node tools/onboarding-tooling.js check --strict",
    "onboarding:scaffold": "node tools/onboarding-tooling.js scaffold",
    "bench:vendors:list": "node tools/vendor-bench.js list",
    "bench:vendors:validate": "node tools/vendor-bench.js validate",
    "bench:vendors:matrix": "node tools/vendor-bench.js matrix",
    "kernels:generate": "node tools/generate-wgsl.js",
    "kernels:check": "node tools/generate-wgsl.js --check",
    "kernels:reachability:sync": "node tools/sync-kernel-reachability.js",
    "kernels:reachability:check": "node tools/sync-kernel-reachability.js --check",
    "digests:sync": "node tools/sync-kernel-ref-digests.js",
    "digests:check": "node tools/sync-kernel-ref-digests.js --check",
    "verify": "node tools/run-registry-verify.js",
    "registry:sync:scripts": "node tools/sync-registry-scripts.js",
    "registry:sync:scripts:check": "node tools/sync-registry-scripts.js --check",
    "registry:hf:check": "node tools/check-hf-registry.js",
    "registry:publish:hf": "node tools/publish-hf-registry-model.js",
    "support:matrix:sync": "node tools/sync-model-support-matrix.js",
    "support:matrix:check": "node tools/sync-model-support-matrix.js --check",
    "support:subsystems:sync": "node tools/sync-subsystem-support-matrix.js",
    "support:subsystems:check": "node tools/sync-subsystem-support-matrix.js --check",
    "ci:catalog:check": "npm run registry:sync:scripts:check && npm run support:matrix:check && npm run support:subsystems:check && npm run registry:hf:check",
    "verify:embeddinggemma-300m": "node tools/run-registry-verify.js embeddinggemma-300m",
    "verify:gemma-3-1b-it-q4k-ehf16-af32": "node tools/run-registry-verify.js gemma-3-1b-it-q4k-ehf16-af32",
    "verify:gemma-3-1b-it-wq4k-ef16-hf16": "node tools/run-registry-verify.js gemma-3-1b-it-wq4k-ef16-hf16",
    "verify:gemma-3-270m-it-q4k-ehf16-af32": "node tools/run-registry-verify.js gemma-3-270m-it-q4k-ehf16-af32",
    "verify:gemma-3-270m-it-wq4k-ef16": "node tools/run-registry-verify.js gemma-3-270m-it-wq4k-ef16",
    "verify:gemma-3-270m-it-wq4k-ef16-hf16": "node tools/run-registry-verify.js gemma-3-270m-it-wq4k-ef16-hf16",
    "verify:gemma-3-270m-it-wq4k-ef16-hf16-f32": "node tools/run-registry-verify.js gemma-3-270m-it-wq4k-ef16-hf16-f32",
    "verify:gemma3-1b": "node tools/run-registry-verify.js gemma3-1b",
    "verify:gemma3-270m": "node tools/run-registry-verify.js gemma3-270m",
    "verify:google-embeddinggemma-300m": "node tools/run-registry-verify.js google-embeddinggemma-300m",
    "verify:google-embeddinggemma-300m-q4k-ehf16-af32": "node tools/run-registry-verify.js google-embeddinggemma-300m-q4k-ehf16-af32",
    "verify:google-embeddinggemma-300m-wq4k-ef16": "node tools/run-registry-verify.js google-embeddinggemma-300m-wq4k-ef16",
    "verify:google-gemma-3-1b-it": "node tools/run-registry-verify.js google-gemma-3-1b-it",
    "verify:google-gemma-3-270m-it": "node tools/run-registry-verify.js google-gemma-3-270m-it",
    "verify:google-translategemma-4b-it": "node tools/run-registry-verify.js google-translategemma-4b-it",
    "verify:lfm2-1.2b": "node tools/run-registry-verify.js lfm2-1.2b",
    "verify:lfm2-5-1-2b-instruct-q4k-ehf16-af32": "node tools/run-registry-verify.js lfm2-5-1-2b-instruct-q4k-ehf16-af32",
    "verify:lfm2.5-1.2b": "node tools/run-registry-verify.js lfm2.5-1.2b",
    "verify:liquidai-lfm2.5-1.2b-instruct": "node tools/run-registry-verify.js liquidai-lfm2.5-1.2b-instruct",
    "verify:qwen-3-5-0-8b": "node tools/run-registry-verify.js qwen-3-5-0-8b",
    "verify:qwen-3-5-0-8b-q4k-ehaf16": "node tools/run-registry-verify.js qwen-3-5-0-8b-q4k-ehaf16",
    "verify:qwen-3-5-0-8b-wq4k-ef16-hf16-f16": "node tools/run-registry-verify.js qwen-3-5-0-8b-wq4k-ef16-hf16-f16",
    "verify:qwen-3-5-2b": "node tools/run-registry-verify.js qwen-3-5-2b",
    "verify:qwen-3-5-2b-q4k-ehaf16": "node tools/run-registry-verify.js qwen-3-5-2b-q4k-ehaf16",
    "verify:qwen-3-5-2b-wq4k-ef16-hf16-f16": "node tools/run-registry-verify.js qwen-3-5-2b-wq4k-ef16-hf16-f16",
    "verify:qwen-qwen3.5-0.8b": "node tools/run-registry-verify.js qwen-qwen3.5-0.8b",
    "verify:qwen-qwen3.5-2b": "node tools/run-registry-verify.js qwen-qwen3.5-2b",
    "verify:qwen3-0.8b": "node tools/run-registry-verify.js qwen3-0.8b",
    "verify:qwen3-2b": "node tools/run-registry-verify.js qwen3-2b",
    "verify:translategemma": "node tools/run-registry-verify.js translategemma",
    "verify:translategemma-4b": "node tools/run-registry-verify.js translategemma-4b",
    "verify:translategemma-4b-it-q4k-ehf16-af32": "node tools/run-registry-verify.js translategemma-4b-it-q4k-ehf16-af32",
    "verify:translategemma-4b-it-wq4k-ef16-hf16": "node tools/run-registry-verify.js translategemma-4b-it-wq4k-ef16-hf16"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./tooling": {
      "types": "./src/tooling-exports.d.ts",
      "browser": "./src/tooling-exports.browser.js",
      "import": "./src/tooling-exports.js"
    },
    "./tooling-experimental": {
      "types": "./src/tooling-experimental-exports.d.ts",
      "browser": "./src/tooling-experimental-exports.browser.js",
      "import": "./src/tooling-experimental-exports.js"
    },
    "./loaders": {
      "types": "./src/loaders/index.d.ts",
      "import": "./src/loaders/index.js"
    },
    "./orchestration": {
      "types": "./src/experimental/orchestration/index.d.ts",
      "import": "./src/experimental/orchestration/index.js"
    },
    "./generation": {
      "types": "./src/generation/index.d.ts",
      "import": "./src/generation/index.js"
    },
    "./diffusion": {
      "types": "./src/experimental/diffusion/index.d.ts",
      "import": "./src/experimental/diffusion/index.js"
    },
    "./energy": {
      "types": "./src/experimental/energy/index.d.ts",
      "import": "./src/experimental/energy/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clocksmith/doppler.git"
  },
  "homepage": "https://github.com/clocksmith/doppler",
  "keywords": [
    "doppler",
    "webgpu",
    "inference",
    "llm",
    "quantized",
    "browser",
    "local"
  ],
  "author": "clocksmith",
  "bugs": {
    "url": "https://github.com/clocksmith/doppler/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "src/gpu/kernels/*.wgsl",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "BRANDING.md",
    "SECURITY.md",
    "src/cli/doppler-cli.js",
    "tools/convert-safetensors-node.js",
    "src/cli/config/doppler-quickstart.json",
    "src/cli/doppler-quickstart.js",
    "src/cli/doppler-serve.js"
  ],
  "devDependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@types/node": "^25.6.0",
    "@webgpu/types": "^0.1.69",
    "jest": "^30.2.0",
    "onnxruntime-web": "^1.24.1",
    "playwright": "^1.58.2",
    "typescript": "^6.0.2"
  },
  "optionalDependencies": {
    "webgpu": "^0.4.0"
  }
