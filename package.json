{
  "name": "@doppler/core",
  "version": "0.1.0",
  "description": "Browser-native WebGPU runtime for local intent and inference loops",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "bin": {
    "doppler": "./tools/doppler-cli.js"
  },
  "scripts": {
    "cli": "node tools/doppler-cli.js",
    "convert": "node tools/doppler-cli.js convert",
    "manifest-refresh": "node tools/refresh-converted-manifest.js",
    "debug": "node tools/doppler-cli.js debug",
    "bench": "node tools/doppler-cli.js bench",
    "bench:chart": "node ./benchmarks/vendors/compare-chart.js",
    "test:unit": "node tools/run-node-tests.mjs --suite unit",
    "test:gpu": "node tools/run-node-tests.mjs --suite gpu",
    "test:coverage": "node tools/run-node-coverage.mjs",
    "test:coverage:report": "node tools/run-node-coverage.mjs --no-threshold",
    "test:gpu:browser": "node tools/doppler-cli.js verify --config '{\"request\":{\"suite\":\"kernels\"},\"run\":{\"surface\":\"browser\",\"browser\":{\"opfsCache\":false,\"headless\":true,\"channel\":\"chromium\",\"browserArgs\":[\"--use-angle=swiftshader\",\"--disable-vulkan-surface\"],\"console\":true}}}'",
    "agents:verify": "node tools/verify-agent-parity.js",
    "agents:freshness": "node tools/verify-agent-freshness.js",
    "agents:freshness:strict": "node tools/verify-agent-freshness.js --strict",
    "conflicts:check": "node tools/check-merge-markers.js",
    "verify:model": "node tools/doppler-cli.js verify",
    "onboarding:check": "node tools/onboarding-tooling.js check",
    "onboarding:check:strict": "node tools/onboarding-tooling.js check --strict",
    "onboarding:scaffold": "node tools/onboarding-tooling.js scaffold",
    "bench:vendors:list": "node tools/vendor-bench.js list",
    "bench:vendors:validate": "node tools/vendor-bench.js validate",
    "bench:vendors:matrix": "node tools/vendor-bench.js matrix",
    "kernels:generate": "node tools/generate-wgsl.js",
    "kernels:check": "node tools/generate-wgsl.js --check"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./provider": {
      "types": "./src/client/doppler-provider.d.ts",
      "import": "./src/client/doppler-provider.js"
    },
    "./*": "./src/*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/clocksmith/doppler.git"
  },
  "homepage": "https://github.com/clocksmith/doppler",
  "keywords": [
    "doppler",
    "webgpu",
    "inference",
    "llm",
    "quantized",
    "browser",
    "local"
  ],
  "author": "clocksmith",
  "bugs": {
    "url": "https://github.com/clocksmith/doppler/issues"
  },
  "license": "Apache-2.0",
  "files": [
    "src",
    "src/gpu/kernels/*.wgsl",
    "README.md",
    "LICENSE",
    "NOTICE",
    "BRANDING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "tools/doppler-cli.js",
    "tools/convert-safetensors-node.js"
  ],
  "devDependencies": {
    "jest": "^30.2.0",
    "playwright": "^1.58.2"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-web": "^1.24.1"
  }
}
