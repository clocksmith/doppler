    "overlapPolicy": "No specification, kernel family, interface contract, reference shader, oracle fixture, input seed, or generated candidate may overlap population roles. Visible mechanics tasks have no population role."
  },
  "taskContract": {
    "responseEnvelope": {
      "id": "complete_wgsl_compute_shader_only_v1",
      "maxCharacters": 16000,
      "forbidMarkdownFences": true,
      "requireComputeStage": true
    },
    "compilationPrerequisite": "chromium_webgpu_compile_must_pass_before_dispatch",
    "actualDispatchRequired": true,
    "cpuOracle": {
      "required": true,
      "implementationRevision": "wgsl-semantic-cpu-oracles-v1",
      "inputAndOutputHashBinding": true
    },
    "numericalAgreement": {
      "formula": "abs(actual-reference) <= absTolerance + relTolerance * abs(reference)",
      "nonFinitePolicy": "unexpected_nan_or_infinity_fails; expected_nonfinite_requires_exact_class_and_sign",
      "tiers": {
        "integerAndBoolean": { "mode": "exact", "absTolerance": 0, "relTolerance": 0 },
        "float32": { "mode": "numeric", "absTolerance": 0.00001, "relTolerance": 0.0001 },
        "float16": { "mode": "numeric", "absTolerance": 0.002, "relTolerance": 0.02 }
      },
      "wideningRule": "Per-task tolerances may be narrower; wider tolerances require a new policy revision frozen before candidate evaluation."
    },
    "shapeVariation": {
      "minimumDistinctShapesPerTask": 3,
      "requiredClasses": ["nominal", "non_workgroup_multiple", "boundary_or_tail"]
    },
    "workgroupVariation": {
      "minimumSemanticallyValidVariantsPerTask": 2,
      "referenceAndCandidateUseIdenticalVariants": true
    },
    "bufferBounds": {
      "prefixCanaryElements": 16,
      "suffixCanaryElements": 16,
      "readOnlyBuffersMustRemainByteIdentical": true,
      "outputPaddingMustRemainByteIdentical": true,
      "unexpectedValidationErrorFails": true
    },
    "metamorphic": {
      "minimumApplicableRelationsPerTask": 2,
      "allowedRelations": [
        "input_permutation_equivariance",
        "zero_or_identity_relation",
        "scale_relation",
        "tiling_equivalence",
        "shape_partition_equivalence",
        "task_specific_adjudicated_invariant"
      ],
      "referenceQualificationRequired": true
    },
    "historicalRegressions": {
      "required": true,
      "manifestPath": "tools/data/wgsl-repair-v13-historical-regressions.json",
      "manifestSha256": "0cf12c4641fad4e99994d6d3b1162569d674bf82f6749b7297984027122e9c23"
    }
  },
