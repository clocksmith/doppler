  "sourceTensors": {
    "requireAll": true,
    "rules": [
      {
        "kind": "rename",
        "match": "^esm\\.embeddings\\.word_embeddings\\.weight$",
        "replace": "model.embed_tokens.weight",
        "expectedMatches": 1,
        "role": "embedding",
        "group": "embed"
      },
      {
        "kind": "ignore",
        "match": "^esm\\.embeddings\\.position_embeddings\\.weight$",
        "expectedMatches": 1,
        "reason": "The checkpoint declares rotary positions; the serialized absolute-position table is not read by the encoder."
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.emb_layer_norm_after\\.weight$",
        "replace": "model.norm.weight",
        "expectedMatches": 1,
        "role": "norm",
        "group": "head"
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.emb_layer_norm_after\\.bias$",
        "replace": "model.norm.bias",
        "expectedMatches": 1,
        "role": "other",
        "group": "head"
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.LayerNorm\\.weight$",
        "replace": "model.layers.$1.input_layernorm.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.LayerNorm\\.bias$",
        "replace": "model.layers.$1.input_layernorm.bias",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.query\\.weight$",
        "replace": "model.layers.$1.self_attn.q_proj.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.query\\.bias$",
        "replace": "model.layers.$1.self_attn.q_proj.bias",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.key\\.weight$",
        "replace": "model.layers.$1.self_attn.k_proj.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.key\\.bias$",
        "replace": "model.layers.$1.self_attn.k_proj.bias",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.value\\.weight$",
        "replace": "model.layers.$1.self_attn.v_proj.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.self\\.value\\.bias$",
        "replace": "model.layers.$1.self_attn.v_proj.bias",
        "expectedMatches": 12
      },
      {
        "kind": "ignore",
        "match": "^esm\\.encoder\\.layer\\.\\d+\\.attention\\.self\\.rotary_embeddings\\.inv_freq$",
        "expectedMatches": 12,
        "reason": "RoPE frequencies are deterministically generated from theta=10000 and headDim=32."
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.output\\.dense\\.weight$",
        "replace": "model.layers.$1.self_attn.o_proj.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.attention\\.output\\.dense\\.bias$",
        "replace": "model.layers.$1.self_attn.o_proj.bias",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.LayerNorm\\.weight$",
        "replace": "model.layers.$1.post_attention_layernorm.weight",
        "expectedMatches": 12
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.LayerNorm\\.bias$",
        "replace": "model.layers.$1.post_attention_layernorm.bias",
        "expectedMatches": 12
      },
      {
        "kind": "split",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.intermediate\\.dense\\.weight$",
        "axis": 0,
        "expectedMatches": 12,
        "parts": [
          { "replace": "model.layers.$1.mlp.gate_proj.weight", "size": 2048 },
          { "replace": "model.layers.$1.mlp.up_proj.weight", "size": 2048 }
        ]
      },
      {
        "kind": "rename",
        "match": "^esm\\.encoder\\.layer\\.(\\d+)\\.output\\.dense\\.weight$",
        "replace": "model.layers.$1.mlp.down_proj.weight",
        "expectedMatches": 12
      },
      {
        "kind": "ignore",
        "match": "^esm\\.contact_head\\.",
        "expectedMatches": 2,
        "reason": "Contact prediction is outside the initial DNA sequence-embedding lane."
      },
      {
        "kind": "ignore",
        "match": "^lm_head\\.",
        "expectedMatches": 6,
        "reason": "Masked-token logits require the checkpoint's dense-exact-GELU-LayerNorm output head; the initial lane is embeddings-only."
      }
    ]
  },
