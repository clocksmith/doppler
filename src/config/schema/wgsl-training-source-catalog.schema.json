{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppler.dev/schemas/wgsl-training-source-catalog.schema.json",
  "title": "Doppler WGSL Training Source Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "catalogId",
    "claimBoundary",
    "sources"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "source": { "const": "doppler" },
    "catalogId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "claimBoundary": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceEntry" }
    }
  },
  "$defs": {
    "sourceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repository",
        "revision",
        "license",
        "parserKind",
        "includeRoots",
        "allowTraining",
        "role",
        "notes"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "repository": { "type": "string", "pattern": "^https://" },
        "revision": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "license": { "type": "string", "minLength": 1 },
        "parserKind": {
          "enum": [
            "wgsl_files",
            "templated_wgsl",
            "typescript_generators",
            "compiler_reference"
          ]
        },
        "localPath": { "type": "string", "minLength": 1 },
        "includeRoots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "excludePathContains": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "allowTraining": { "type": "boolean" },
        "role": {
          "enum": [
            "primary_in_domain",
            "external_ood",
            "reference_only",
            "quarantined"
          ]
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
