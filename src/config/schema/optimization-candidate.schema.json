{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.dev/doppler/schemas/runtime-optimization-candidate-v1.schema.json",
  "title": "Doppler runtime optimization candidate v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "candidateId", "contractHash", "parentHash", "patch"],
  "properties": {
    "schema": { "const": "doppler.runtime-optimization-candidate/v1" },
    "candidateId": { "type": "string", "minLength": 1 },
    "contractHash": { "$ref": "#/$defs/digest" },
    "parentHash": { "$ref": "#/$defs/digest" },
    "patch": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op", "path", "value"],
        "properties": {
          "op": { "const": "set" },
          "path": { "type": "string", "pattern": "^/" },
          "value": true
        }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
