{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.dev/doppler/schemas/wgsl-repair-confirmation-materialization-v1.schema.json",
  "title": "WGSL repair V13 confirmation materialization policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "policyId",
    "status",
    "generator",
    "catalog",
    "oracleImplementation",
    "entropy",
    "selection",
    "outputs",
    "freezeProtocol",
    "authority",
    "claimBoundary"
  ],
  "properties": {
    "$schema": {
      "const": "../../src/config/schema/wgsl-repair-confirmation-materialization.schema.json"
    },
    "schemaVersion": { "const": 1 },
    "source": { "const": "doppler" },
    "policyId": { "const": "doppler-wgsl-repair-v13-seed-confirmation-materialization" },
    "status": { "const": "frozen_before_population_materialization" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "const": "tools/materialize-wgsl-repair-v13-confirmation.js" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "eligibleBlueprintCount"],
      "properties": {
        "path": { "const": "tools/data/wgsl-repair-v13-confirmation-blueprints.json" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "eligibleBlueprintCount": { "const": 12 }
      }
    },
    "oracleImplementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "revision"],
      "properties": {
        "path": { "const": "tools/lib/wgsl-semantic-harness.js" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "revision": { "const": "wgsl-semantic-cpu-oracles-v1" }
      }
    },
    "entropy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "commitRequirement", "domainSeparator"],
      "properties": {
        "source": { "const": "freeze_commit_sha" },
        "commitRequirement": {
          "const": "full_commit_must_contain_byte_identical_policy_generator_and_catalog"
        },
        "domainSeparator": { "const": "doppler-wgsl-v13-confirmation-v1" }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "taskCount", "strata", "subsetRule", "parameterRule"],
      "properties": {
        "algorithm": { "const": "commit_sha256_stratified_blueprint_subset_v2" },
        "taskCount": { "const": 8 },
        "strata": {
          "const": [
            {
              "id": "binary_parameterized",
              "arity": "binary",
              "parameterized": true,
              "count": 1
            },
            {
              "id": "binary_nonparameterized",
              "arity": "binary",
              "parameterized": false,
              "count": 3
            },
            {
              "id": "unary_parameterized",
              "arity": "unary",
              "parameterized": true,
              "count": 3
            },
            {
              "id": "unary_nonparameterized",
              "arity": "unary",
              "parameterized": false,
              "count": 1
            }
          ]
        },
        "subsetRule": {
          "const": "within frozen arity and parameterization strata, rank blueprint ids by domain-separated SHA-256 and take each declared count"
        },
        "parameterRule": {
          "const": "select declared parameter values, input seeds, and shape variants from independent domain-separated SHA-256 digests"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestPath", "fixtureDirectory"],
      "properties": {
        "manifestPath": {
          "const": "tools/data/wgsl-repair-v13-semantic-seed-confirmation.json"
        },
        "fixtureDirectory": {
          "const": "tests/fixtures/wgsl-repair-v13/confirmation"
        }
      }
    },
    "freezeProtocol": {
      "const": [
        "commit_and_push_this_policy_generator_catalog_and_oracle_implementation",
        "derive_the_population_from_that_exact_commit_without_candidate_inference",
        "commit_and_push_the_generated_sources_manifest_and_evaluation_policy",
        "qualify_every_reference_dispatch_before_candidate_inference",
        "run_selected_seed_29_exactly_once_on_the_frozen_confirmation_population"
      ]
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateInferenceBeforePopulationFreeze",
        "seedConfirmation",
        "promotion",
        "wgslDoctor",
        "completeShaderWriting"
      ],
      "properties": {
        "candidateInferenceBeforePopulationFreeze": { "const": false },
        "seedConfirmation": { "const": true },
        "promotion": { "const": false },
        "wgslDoctor": { "const": false },
        "completeShaderWriting": { "const": false }
      }
    },
    "claimBoundary": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
