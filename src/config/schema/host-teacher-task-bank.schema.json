{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppler.dev/schemas/host-teacher-task-bank.schema.json",
  "title": "Doppler Host Teacher Task Bank",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "bankId",
    "baseRevision",
    "studentBaseModelId",
    "tasks"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "source": { "const": "doppler" },
    "bankId": { "type": "string", "minLength": 1 },
    "baseRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "studentBaseModelId": { "type": "string", "minLength": 1 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "repoPaths": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/repoPath" }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command", "args"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "args": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "find", "replace", "occurrences"],
      "properties": {
        "path": { "$ref": "#/$defs/repoPath" },
        "find": { "type": "string", "minLength": 1 },
        "replace": { "type": "string" },
        "occurrences": { "type": "integer", "minimum": 1 }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "lane",
        "split",
        "title",
        "prompt",
        "sourceFiles",
        "allowedChangedPaths",
        "mutations",
        "validationCommands"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "lane": { "enum": ["javascript", "wgsl"] },
        "split": { "enum": ["qualification", "label", "student_holdout"] },
        "title": { "type": "string", "minLength": 1 },
        "prompt": { "type": "string", "minLength": 1 },
        "sourceFiles": { "$ref": "#/$defs/repoPaths" },
        "allowedChangedPaths": { "$ref": "#/$defs/repoPaths" },
        "mutations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/mutation" }
        },
        "validationCommands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/command" }
        }
      }
    }
  }
}
