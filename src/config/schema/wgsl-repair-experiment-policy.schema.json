{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppler.dev/schemas/wgsl-repair-experiment-policy.schema.json",
  "title": "Doppler WGSL Repair Experiment Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "policyId",
    "status",
    "claimBoundary",
    "sourceCatalogPath",
    "corpus",
    "models",
    "trainer",
    "methods",
    "verifier",
    "promotion",
    "requiredArtifactTypes"
  ],
  "properties": {
    "$schema": { "type": "string", "minLength": 1 },
    "schemaVersion": { "const": 1 },
    "source": { "const": "doppler" },
    "policyId": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "status": { "enum": ["draft", "frozen", "retired"] },
    "claimBoundary": { "type": "string", "minLength": 1 },
    "sourceCatalogPath": { "$ref": "#/$defs/repoPath" },
    "corpus": { "$ref": "#/$defs/corpus" },
    "models": { "type": "object", "minProperties": 1 },
    "trainer": { "type": "object", "minProperties": 1 },
    "methods": { "type": "object", "minProperties": 1 },
    "verifier": { "type": "object", "minProperties": 1 },
    "promotion": { "type": "object", "minProperties": 1 },
    "requiredArtifactTypes": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "training_rollout_group",
          "training_reward_vector",
          "training_policy_update",
          "training_verifier_report",
          "training_policy_checkpoint",
          "training_promotion_decision"
        ]
      }
    }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "taskContract",
        "targetVerifiedRows",
        "minimumVerifiedRows",
        "minimumDistinctKernels",
        "fixedExternalTrainingFraction",
        "laneRows",
        "laneSeed",
        "lanes",
        "splitKey",
        "splits",
        "mutationOperators",
        "admission"
      ],
      "properties": {
        "taskContract": { "const": "replacement_only_wgsl_span_v1" },
        "targetVerifiedRows": { "type": "integer", "minimum": 1 },
        "minimumVerifiedRows": { "type": "integer", "minimum": 1 },
        "minimumDistinctKernels": { "type": "integer", "minimum": 1 },
        "fixedExternalTrainingFraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "laneRows": { "type": "integer", "minimum": 1 },
        "laneSeed": { "type": "integer", "minimum": 0 },
        "lanes": { "type": "object", "minProperties": 3 },
        "splitKey": { "const": "kernelFamilyId" },
        "splits": { "type": "object", "minProperties": 3 },
        "mutationOperators": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "admission": { "type": "object", "minProperties": 1 }
      }
    }
  }
}
