{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.dev/doppler/schemas/wgsl-writer-blueprint-catalog-v1.schema.json",
  "title": "WGSL writer blueprint catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "source",
    "catalogId",
    "license",
    "taskScope",
    "excludedOracleIds",
    "blueprints"
  ],
  "properties": {
    "$schema": {
      "const": "../../src/config/schema/wgsl-writer-blueprint-catalog.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "source": {
      "const": "doppler"
    },
    "catalogId": {
      "const": "doppler-wgsl-writer-elementwise-f32-v1"
    },
    "license": {
      "const": "Apache-2.0"
    },
    "taskScope": {
      "const": "complete_1d_elementwise_f32_compute_shader_from_explicit_interface"
    },
    "excludedOracleIds": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blueprints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/blueprint"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "blueprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "oracleId",
        "arity",
        "operationDescription",
        "expression",
        "firstField",
        "firstParameterKey",
        "parameters"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "role": {
          "enum": [
            "training",
            "calibration",
            "checkpoint_selection",
            "seed_confirmation"
          ]
        },
        "oracleId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*_f32$"
        },
        "arity": {
          "enum": [
            "unary",
            "binary"
          ]
        },
        "operationDescription": {
          "type": "string",
          "minLength": 1
        },
        "expression": {
          "type": "string",
          "minLength": 1
        },
        "firstField": {
          "$ref": "#/$defs/identifier"
        },
        "firstParameterKey": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    }
  }
}
