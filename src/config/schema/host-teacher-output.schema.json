{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppler.dev/schemas/host-teacher-output.schema.json",
  "title": "Doppler Host Teacher Final Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "summary",
    "changedFiles",
    "verification",
    "residualRisks"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "changedFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
