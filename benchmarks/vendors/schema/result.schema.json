{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Vendor Benchmark Result",
  "type": "object",
  "required": [
    "schemaVersion",
    "timestamp",
    "target",
    "harness",
    "workload",
    "model",
    "metrics",
    "source",
    "environment"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "timestamp": { "type": "string" },
    "target": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "harness": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "workload": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": ["number", "null"]
      }
    },
    "source": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string" },
        "inputPath": { "type": ["string", "null"] },
        "command": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "host": {
          "type": ["object", "null"],
          "required": ["platform", "arch", "nodeVersion", "osRelease", "cpuModel"],
          "properties": {
            "platform": { "type": ["string", "null"] },
            "arch": { "type": ["string", "null"] },
            "nodeVersion": { "type": ["string", "null"] },
            "osRelease": { "type": ["string", "null"] },
            "cpuModel": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "rawSha256": { "type": ["string", "null"] },
        "rawBytes": { "type": ["integer", "null"] }
      },
      "additionalProperties": true
    },
    "environment": {
      "type": "object",
      "required": ["host", "browser", "gpu", "runtime"],
      "properties": {
        "host": {
          "type": "object",
          "required": ["platform", "arch", "nodeVersion", "osRelease", "cpuModel"],
          "properties": {
            "platform": { "type": ["string", "null"] },
            "arch": { "type": ["string", "null"] },
            "nodeVersion": { "type": ["string", "null"] },
            "osRelease": { "type": ["string", "null"] },
            "cpuModel": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "browser": {
          "type": "object",
          "required": ["userAgent", "platform", "language", "vendor", "executable", "channel"],
          "properties": {
            "userAgent": { "type": ["string", "null"] },
            "platform": { "type": ["string", "null"] },
            "language": { "type": ["string", "null"] },
            "vendor": { "type": ["string", "null"] },
            "executable": { "type": ["string", "null"] },
            "channel": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "gpu": {
          "type": "object",
          "required": [
            "api",
            "backend",
            "vendor",
            "architecture",
            "device",
            "description",
            "hasF16",
            "hasSubgroups",
            "hasTimestampQuery"
          ],
          "properties": {
            "api": { "type": ["string", "null"] },
            "backend": { "type": ["string", "null"] },
            "vendor": { "type": ["string", "null"] },
            "architecture": { "type": ["string", "null"] },
            "device": { "type": ["string", "null"] },
            "description": { "type": ["string", "null"] },
            "hasF16": { "type": ["boolean", "null"] },
            "hasSubgroups": { "type": ["boolean", "null"] },
            "hasTimestampQuery": { "type": ["boolean", "null"] }
          },
          "additionalProperties": false
        },
        "runtime": {
          "type": "object",
          "required": [
            "library",
            "version",
            "surface",
            "device",
            "dtype",
            "requestedDtype",
            "executionProviderMode",
            "cacheMode",
            "loadMode"
          ],
          "properties": {
            "library": { "type": ["string", "null"] },
            "version": { "type": ["string", "null"] },
            "surface": { "type": ["string", "null"] },
            "device": { "type": ["string", "null"] },
            "dtype": { "type": ["string", "null"] },
            "requestedDtype": { "type": ["string", "null"] },
            "executionProviderMode": { "type": ["string", "null"] },
            "cacheMode": { "type": ["string", "null"] },
            "loadMode": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "notes": { "type": ["string", "null"] },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
