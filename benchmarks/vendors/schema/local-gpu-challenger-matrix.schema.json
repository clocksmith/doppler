{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clocksmith.ai/doppler/schemas/local-gpu-challenger-matrix.schema.json",
  "title": "Local GPU Challenger Matrix",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "matrixId",
    "updated",
    "purpose",
    "selectionPolicy",
    "platformTargets",
    "fairnessGates",
    "competitors",
    "harnesses",
    "models"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "schema/local-gpu-challenger-matrix.schema.json"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "matrixId": {
      "type": "string",
      "const": "local-gpu-challenger-matrix"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "selectionPolicy": {
      "type": "object",
      "required": [
        "hostClass",
        "probeHostClass",
        "anchorCompetitorId",
        "minAdditionalLocalChallengers",
        "claimGradeOrder",
        "fallbackPolicy",
        "sharedContractPolicy"
      ],
      "properties": {
        "hostClass": {
          "type": "string",
          "minLength": 1
        },
        "probeHostClass": {
          "type": "string",
          "minLength": 1
        },
        "anchorCompetitorId": {
          "type": "string",
          "minLength": 1
        },
        "minAdditionalLocalChallengers": {
          "type": "integer",
          "minimum": 1
        },
        "claimGradeOrder": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/claimGrade"
          }
        },
        "fallbackPolicy": {
          "type": "string",
          "const": "fail-closed"
        },
        "sharedContractPolicy": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "platformTargets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "os",
          "accelerators",
          "runtimeSurfaces",
          "status"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/kebabId"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "os": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "accelerators": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "runtimeSurfaces": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "status": {
            "type": "string",
            "enum": [
              "local-probe-supported",
              "planned"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "fairnessGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "requires"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/kebabId"
          },
          "requires": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "competitors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "runtimeSurface",
          "backend",
          "format",
          "claimScope",
          "availability",
          "fallbackPolicy",
          "evidenceKind"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/kebabId"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "runtimeSurface": {
            "type": "string",
            "minLength": 1
          },
          "backend": {
            "type": "string",
            "minLength": 1
          },
          "format": {
            "type": "string",
            "enum": [
              "onnx",
              "gguf",
              "safetensors",
              "litert"
            ]
          },
          "claimScope": {
            "type": "string",
            "enum": [
              "anchor",
              "local-challenger"
            ]
          },
          "availability": {
            "type": "string",
            "enum": [
              "configured",
              "artifact-needed",
              "runner-needed",
              "artifact-and-runner-needed",
              "environment-needed",
              "runtime-smoke-failed",
              "blocked-pytorch-rocm-unavailable"
            ]
          },
          "fallbackPolicy": {
            "type": "string",
            "const": "fail-closed"
          },
          "evidenceKind": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "harnesses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "workloadClass",
          "sharedContract",
          "engineOverlayPolicy",
          "metrics",
          "fairnessGates",
          "claimGrades"
        ],
        "properties": {
          "id": {
            "$ref": "#/$defs/kebabId"
          },
          "workloadClass": {
            "type": "string",
            "minLength": 1
          },
          "sharedContract": {
            "type": "object",
            "required": [
              "workloads",
              "sampling",
              "cacheModes",
              "runCounts",
              "correctness"
            ],
            "properties": {
              "workloads": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "sampling": {
                "type": [
                  "object",
                  "null"
                ],
                "properties": {
                  "temperature": {
                    "type": "number",
                    "minimum": 0
                  },
                  "topK": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "topP": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "maximum": 1
                  },
                  "seed": {
                    "type": "integer"
                  }
                },
                "required": [
                  "temperature",
                  "topK",
                  "topP",
                  "seed"
                ],
                "additionalProperties": false
              },
              "cacheModes": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "runCounts": {
                "type": "object",
                "required": [
                  "warmupRuns",
                  "timedRuns",
                  "minTimedSamplesForPercentiles"
                ],
                "properties": {
                  "warmupRuns": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "timedRuns": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "minTimedSamplesForPercentiles": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "additionalProperties": false
              },
              "correctness": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "engineOverlayPolicy": {
            "type": "object",
            "required": [
              "dopplerAllowed",
              "competitorAllowed",
              "forbiddenSharedFields"
            ],
            "properties": {
              "dopplerAllowed": {
                "$ref": "#/$defs/nonEmptyStringArray"
              },
              "competitorAllowed": {
                "$ref": "#/$defs/nonEmptyStringArray"
              },
              "forbiddenSharedFields": {
                "$ref": "#/$defs/nonEmptyStringArray"
              }
            },
            "additionalProperties": false
          },
          "metrics": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "fairnessGates": {
            "$ref": "#/$defs/nonEmptyStringArray"
          },
          "claimGrades": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/claimGrade"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "modelId",
          "publicModelName",
          "tier",
          "modelRole",
          "sourceCheckpoint",
          "dopplerArtifactId",
          "alternateDopplerArtifactIds",
          "anchorComparator",
          "localChallengers",
          "recommendedHarnesses",
          "claimPolicy"
        ],
        "properties": {
          "modelId": {
            "$ref": "#/$defs/modelId"
          },
          "publicModelName": {
            "type": "string",
            "minLength": 1
          },
          "tier": {
            "type": "string",
            "enum": [
              "tier-0",
              "tier-1",
              "tier-2",
              "tier-3"
            ]
          },
          "modelRole": {
            "type": "string",
            "enum": [
              "generation",
              "embedding",
              "rerank"
            ]
          },
          "sourceCheckpoint": {
            "type": "string",
            "minLength": 1
          },
          "dopplerArtifactId": {
            "$ref": "#/$defs/modelId"
          },
          "alternateDopplerArtifactIds": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/modelId"
            }
          },
          "anchorComparator": {
            "type": "object",
            "required": [
              "competitorId",
              "modelId",
              "format",
              "dtype",
              "status"
            ],
            "properties": {
              "competitorId": {
                "$ref": "#/$defs/kebabId"
              },
              "modelId": {
                "type": "string",
                "minLength": 1
              },
              "format": {
                "type": "string",
                "minLength": 1
              },
              "dtype": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": [
                  "configured",
                  "missing",
                  "diagnostic",
                  "configured-artifact"
                ]
              }
            },
            "additionalProperties": false
          },
          "latestAnchorEvidence": {
            "type": [
              "object",
              "null"
            ],
            "required": [
              "receiptPath",
              "timestamp",
              "platformTargetId",
              "harnessId",
              "workloadId",
              "warmupRuns",
              "timedRuns",
              "claimGrade",
              "correctness",
              "winner",
              "summary",
              "wins",
              "losses",
              "blockedReasons",
              "metrics"
            ],
            "properties": {
              "receiptPath": {
                "type": "string",
                "minLength": 1
              },
              "timestamp": {
                "type": "string",
                "minLength": 1
              },
              "platformTargetId": {
                "$ref": "#/$defs/kebabId"
              },
              "harnessId": {
                "$ref": "#/$defs/kebabId"
              },
              "workloadId": {
                "type": "string",
                "minLength": 1
              },
              "warmupRuns": {
                "type": "integer",
                "minimum": 0
              },
              "timedRuns": {
                "type": "integer",
                "minimum": 1
              },
              "claimGrade": {
                "type": "string",
                "enum": [
                  "release-claimable",
                  "local-gpu-comparable",
                  "diagnostic",
                  "not-claim-grade"
                ]
              },
              "correctness": {
                "type": "string",
                "enum": [
                  "exact-match",
                  "semantic-pass",
                  "mismatch"
                ]
              },
              "winner": {
                "type": "string",
                "enum": [
                  "doppler",
                  "transformersjs",
                  "mixed",
                  "blocked"
                ]
              },
              "summary": {
                "type": "string",
                "minLength": 1
              },
              "wins": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "losses": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "blockedReasons": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "metrics": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "id",
                    "doppler",
                    "competitor",
                    "ratio",
                    "higherBetter"
                  ],
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "doppler": {
                      "type": "number"
                    },
                    "competitor": {
                      "type": "number"
                    },
                    "ratio": {
                      "type": "number"
                    },
                    "higherBetter": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "localChallengers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "competitorId",
                "candidateArtifact",
                "status",
                "nextGate"
              ],
              "properties": {
                "competitorId": {
                  "$ref": "#/$defs/kebabId"
                },
                "candidateArtifact": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "diagnostic",
                    "runner-needed",
                    "artifact-needed",
                    "artifact-and-runner-needed",
                    "environment-needed",
                    "runtime-smoke-failed",
                    "blocked-pytorch-rocm-unavailable",
                    "configured"
                  ]
                },
                "nextGate": {
                  "$ref": "#/$defs/kebabId"
                },
                "latestEvidence": {
                  "type": [
                    "object",
                    "null"
                  ],
                  "required": [
                    "receiptPaths",
                    "timestamp",
                    "platformTargetId",
                    "harnessId",
                    "claimGrade",
                    "correctness",
                    "winner",
                    "summary",
                    "wins",
                    "losses",
                    "blockedReasons",
                    "metrics"
                  ],
                  "properties": {
                    "receiptPaths": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "timestamp": {
                      "type": "string",
                      "minLength": 1
                    },
                    "platformTargetId": {
                      "$ref": "#/$defs/kebabId"
                    },
                    "harnessId": {
                      "$ref": "#/$defs/kebabId"
                    },
                    "claimGrade": {
                      "type": "string",
                      "enum": [
                        "release-claimable",
                        "local-gpu-comparable",
                        "diagnostic",
                        "not-claim-grade"
                      ]
                    },
                    "correctness": {
                      "type": "string",
                      "enum": [
                        "exact-match",
                        "semantic-pass",
                        "mismatch",
                        "not-measured"
                      ]
                    },
                    "winner": {
                      "type": "string",
                      "enum": [
                        "doppler",
                        "local-challenger",
                        "mixed",
                        "blocked"
                      ]
                    },
                    "summary": {
                      "type": "string",
                      "minLength": 1
                    },
                    "wins": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "losses": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "blockedReasons": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "metrics": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "object",
                        "required": [
                          "id",
                          "doppler",
                          "competitor",
                          "ratio",
                          "higherBetter"
                        ],
                        "properties": {
                          "id": {
                            "type": "string",
                            "minLength": 1
                          },
                          "doppler": {
                            "type": "number"
                          },
                          "competitor": {
                            "type": "number"
                          },
                          "ratio": {
                            "type": "number"
                          },
                          "higherBetter": {
                            "type": "boolean"
                          }
                        },
                        "additionalProperties": false
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "recommendedHarnesses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/kebabId"
            }
          },
          "claimPolicy": {
            "type": "object",
            "required": [
              "minimumClaimGrade",
              "releasePromotion"
            ],
            "properties": {
              "minimumClaimGrade": {
                "$ref": "#/$defs/claimGrade"
              },
              "releasePromotion": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "claimGrade": {
      "type": "string",
      "enum": [
        "diagnostic",
        "local-gpu-comparable",
        "release-claimable"
      ]
    },
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "modelId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
