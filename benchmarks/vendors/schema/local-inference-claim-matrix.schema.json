{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Inference Claim Matrix",
  "type": "object",
  "required": [
    "schemaVersion",
    "matrixId",
    "updated",
    "refreshedAt",
    "refreshSources",
    "selectionPolicy",
    "sharedRunContract",
    "promotionGates",
    "requiredMeasurements",
    "lanes"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "matrixId": {
      "type": "string",
      "minLength": 1
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "refreshedAt": {
      "type": "string",
      "minLength": 1
    },
    "refreshSources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "locator",
          "checkedAt",
          "purpose"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9:-]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "local-json",
              "local-manifest",
              "huggingface-model",
              "huggingface-collection",
              "vendor-doc"
            ]
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "checkedAt": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "selectionPolicy": {
      "type": "object",
      "required": [
        "scope",
        "machineClass",
        "maxArtifactBytes",
        "minSystemMemoryBytes",
        "requiresLocalManifest",
        "requiresArtifactHashes",
        "requiresCompareProfile",
        "requiresVerifiedLocalExecution",
        "allowedRuntimeStatuses",
        "allowedCompressionFormats",
        "excludedModelTypes"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "machineClass": {
          "type": "string",
          "minLength": 1
        },
        "maxArtifactBytes": {
          "type": "integer",
          "minimum": 1
        },
        "minSystemMemoryBytes": {
          "type": "integer",
          "minimum": 1
        },
        "requiresLocalManifest": {
          "type": "boolean"
        },
        "requiresArtifactHashes": {
          "type": "boolean"
        },
        "requiresCompareProfile": {
          "type": "boolean"
        },
        "requiresVerifiedLocalExecution": {
          "type": "boolean"
        },
        "allowedRuntimeStatuses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowedCompressionFormats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excludedModelTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "sharedRunContract": {
      "type": "object",
      "required": [
        "promptSet",
        "workloads",
        "contextLengths",
        "warmupRuns",
        "timedRuns",
        "minTimedSamplesForPercentiles",
        "minDecodeTokens",
        "samplingPolicy",
        "batchDecodeProfiles",
        "requiredRuntimeBackends",
        "timingScope",
        "memoryResidency",
        "competitorPolicy"
      ],
      "properties": {
        "promptSet": {
          "type": "string",
          "minLength": 1
        },
        "workloads": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          }
        },
        "contextLengths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "warmupRuns": {
          "type": "integer",
          "minimum": 0
        },
        "timedRuns": {
          "type": "integer",
          "minimum": 1
        },
        "minTimedSamplesForPercentiles": {
          "type": "integer",
          "minimum": 3
        },
        "minDecodeTokens": {
          "type": "integer",
          "minimum": 1
        },
        "samplingPolicy": {
          "type": "object",
          "required": [
            "temperature",
            "topK",
            "topP",
            "seed"
          ],
          "properties": {
            "temperature": {
              "type": "number",
              "minimum": 0
            },
            "topK": {
              "type": "integer",
              "minimum": 1
            },
            "topP": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            },
            "seed": {
              "type": "integer"
            }
          },
          "additionalProperties": false
        },
        "batchDecodeProfiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "batchSize",
              "readbackInterval",
              "disableMultiTokenDecode",
              "stopCheckMode"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "batchSize": {
                "type": "integer",
                "minimum": 1
              },
              "readbackInterval": {
                "type": "integer",
                "minimum": 1
              },
              "disableMultiTokenDecode": {
                "type": "boolean"
              },
              "stopCheckMode": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "requiredRuntimeBackends": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "id",
              "target",
              "surface",
              "backend",
              "format",
              "feature",
              "requiredForPromotion"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "target": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "surface": {
                "type": "string",
                "minLength": 1
              },
              "backend": {
                "type": "string",
                "minLength": 1
              },
              "format": {
                "type": "string",
                "minLength": 1
              },
              "feature": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9_]*$"
              },
              "requiredForPromotion": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "timingScope": {
          "type": "object",
          "required": [
            "prefill",
            "decode",
            "endToEnd",
            "load",
            "readbackAccounting"
          ],
          "properties": {
            "prefill": {
              "type": "string",
              "minLength": 1
            },
            "decode": {
              "type": "string",
              "minLength": 1
            },
            "endToEnd": {
              "type": "string",
              "minLength": 1
            },
            "load": {
              "type": "string",
              "minLength": 1
            },
            "readbackAccounting": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "memoryResidency": {
          "type": "object",
          "required": [
            "loadModes",
            "cacheModes",
            "requireResidentWeights",
            "forbidCpuFallback",
            "recordPeakMemory",
            "recordResidentMemory"
          ],
          "properties": {
            "loadModes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "opfs",
                  "http",
                  "memory"
                ]
              }
            },
            "cacheModes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "cold",
                  "warm"
                ]
              }
            },
            "requireResidentWeights": {
              "type": "boolean"
            },
            "forbidCpuFallback": {
              "type": "boolean"
            },
            "recordPeakMemory": {
              "type": "boolean"
            },
            "recordResidentMemory": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "competitorPolicy": {
          "type": "object",
          "required": [
            "targets",
            "samePrompts",
            "sameSampling",
            "sameHardware",
            "sameThermalPolicy",
            "sameReportShape",
            "sameArtifactsWherePossible"
          ],
          "properties": {
            "targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              }
            },
            "samePrompts": {
              "type": "boolean"
            },
            "sameSampling": {
              "type": "boolean"
            },
            "sameHardware": {
              "type": "boolean"
            },
            "sameThermalPolicy": {
              "type": "boolean"
            },
            "sameReportShape": {
              "type": "boolean"
            },
            "sameArtifactsWherePossible": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "promotionGates": {
      "type": "object",
      "required": [
        "nonZeroExecution",
        "providerImportsOk",
        "noCpuFallback",
        "promptSemanticsMatch",
        "outputSemanticsMatch",
        "stableReadbackAccounting",
        "percentilesPresent",
        "artifactHashesMatch",
        "memoryBudgetRespected",
        "compareArtifactRequired",
        "throughputCadence"
      ],
      "properties": {
        "nonZeroExecution": {
          "type": "boolean"
        },
        "providerImportsOk": {
          "type": "boolean"
        },
        "noCpuFallback": {
          "type": "boolean"
        },
        "promptSemanticsMatch": {
          "type": "boolean"
        },
        "outputSemanticsMatch": {
          "type": "boolean"
        },
        "stableReadbackAccounting": {
          "type": "boolean"
        },
        "percentilesPresent": {
          "type": "boolean"
        },
        "artifactHashesMatch": {
          "type": "boolean"
        },
        "memoryBudgetRespected": {
          "type": "boolean"
        },
        "compareArtifactRequired": {
          "type": "boolean"
        },
        "throughputCadence": {
          "type": "object",
          "required": [
            "requireBatchAccounting",
            "minDecodeTokensPerSecRatioVsParity",
            "minBatchResolutionEfficiency",
            "maxBatchOverrunTokens",
            "description"
          ],
          "properties": {
            "requireBatchAccounting": {
              "type": "boolean"
            },
            "minDecodeTokensPerSecRatioVsParity": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "minBatchResolutionEfficiency": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "maxBatchOverrunTokens": {
              "type": "number",
              "minimum": 0
            },
            "description": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "requiredMeasurements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "statusReason",
          "model",
          "artifact",
          "run",
          "compare",
          "memoryBudget",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "promoted",
              "blocked",
              "diagnostic"
            ]
          },
          "statusReason": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "model": {
            "type": "object",
            "required": [
              "dopplerModelId",
              "label",
              "family",
              "parameterClass",
              "sourceCheckpointId",
              "sourceRevision",
              "tokenizer"
            ],
            "properties": {
              "dopplerModelId": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "family": {
                "type": "string",
                "minLength": 1
              },
              "parameterClass": {
                "type": "string",
                "minLength": 1
              },
              "sourceCheckpointId": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "sourceRevision": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "tokenizer": {
                "type": "object",
                "required": [
                  "type",
                  "file",
                  "sha256",
                  "vocabSize"
                ],
                "properties": {
                  "type": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "minLength": 1
                  },
                  "file": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "minLength": 1
                  },
                  "sha256": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "pattern": "^[a-f0-9]{64}$"
                  },
                  "vocabSize": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "minimum": 1
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "artifact": {
            "type": "object",
            "required": [
              "format",
              "compression",
              "quantization",
              "manifestPath",
              "manifestSha256",
              "weightPackId",
              "weightPackHash",
              "manifestVariantId",
              "shardSetHash",
              "sizeBytes",
              "compressionRatio"
            ],
            "properties": {
              "format": {
                "type": "string",
                "minLength": 1
              },
              "compression": {
                "type": "string",
                "minLength": 1
              },
              "quantization": {
                "type": "string",
                "minLength": 1
              },
              "manifestPath": {
                "type": "string",
                "minLength": 1
              },
              "manifestSha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "weightPackId": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "weightPackHash": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              "manifestVariantId": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "shardSetHash": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^sha256:[a-f0-9]{64}$"
              },
              "sizeBytes": {
                "type": "integer",
                "minimum": 1
              },
              "compressionRatio": {
                "type": [
                  "number",
                  "null"
                ],
                "exclusiveMinimum": 0
              }
            },
            "additionalProperties": false
          },
          "run": {
            "type": "object",
            "required": [
              "contextLengths",
              "workloads",
              "decodeProfiles",
              "runtimeBackends",
              "graphTransforms"
            ],
            "properties": {
              "contextLengths": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "workloads": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                }
              },
              "decodeProfiles": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9][a-z0-9-]*$"
                }
              },
              "runtimeProfileByDecodeProfile": {
                "type": "object",
                "properties": {
                  "parity": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "minLength": 1
                  },
                  "throughput": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              },
              "runtimeBackends": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "target",
                    "surface",
                    "backend",
                    "format",
                    "loadModes"
                  ],
                  "properties": {
                    "target": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9-]*$"
                    },
                    "surface": {
                      "type": "string",
                      "minLength": 1
                    },
                    "backend": {
                      "type": "string",
                      "minLength": 1
                    },
                    "format": {
                      "type": "string",
                      "minLength": 1
                    },
                    "loadModes": {
                      "type": "array",
                      "minItems": 1,
                      "items": {
                        "type": "string",
                        "enum": [
                          "opfs",
                          "http",
                          "memory"
                        ]
                      }
                    }
                  },
                  "additionalProperties": false
                }
              },
              "graphTransforms": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "additionalProperties": false
          },
          "compare": {
            "type": "object",
            "required": [
              "competitors",
              "sameArtifactWherePossible",
              "promptSemantics",
              "outputSemantics",
              "parityCheck"
            ],
            "properties": {
              "competitors": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "target",
                    "modelId",
                    "format",
                    "dtype",
                    "expectedArtifactHash"
                  ],
                  "properties": {
                    "target": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9-]*$"
                    },
                    "modelId": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "minLength": 1
                    },
                    "format": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "minLength": 1
                    },
                    "dtype": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "minLength": 1
                    },
                    "expectedArtifactHash": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "sameArtifactWherePossible": {
                "type": "boolean"
              },
              "promptSemantics": {
                "type": "string",
                "minLength": 1
              },
              "outputSemantics": {
                "type": "string",
                "minLength": 1
              },
              "parityCheck": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          },
          "memoryBudget": {
            "type": "object",
            "required": [
              "artifactBytes",
              "maxResidentBytes",
              "maxPeakBytes"
            ],
            "properties": {
              "artifactBytes": {
                "type": "integer",
                "minimum": 1
              },
              "maxResidentBytes": {
                "type": "integer",
                "minimum": 1
              },
              "maxPeakBytes": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "object",
            "required": [
              "localExecutionReport",
              "compareResult",
              "summarySvg"
            ],
            "properties": {
              "localExecutionReport": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "compareResult": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "summarySvg": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "surfaceCompareResults": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "backendId",
                    "compareResult",
                    "summarySvg"
                  ],
                  "properties": {
                    "backendId": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9-]*$"
                    },
                    "compareResult": {
                      "type": "string",
                      "minLength": 1
                    },
                    "summarySvg": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "workloadCompareResults": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "backendId",
                    "workloadId",
                    "compareResult",
                    "summarySvg"
                  ],
                  "properties": {
                    "backendId": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9-]*$"
                    },
                    "workloadId": {
                      "type": "string",
                      "pattern": "^[a-z0-9][a-z0-9-]*$"
                    },
                    "compareResult": {
                      "type": "string",
                      "minLength": 1
                    },
                    "summarySvg": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
