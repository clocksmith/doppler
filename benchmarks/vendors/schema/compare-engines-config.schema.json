{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compare Engines Config",
  "type": "object",
  "required": ["schemaVersion", "modelProfiles"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updated": {
      "type": "string"
    },
    "modelProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dopplerModelId"],
        "properties": {
          "dopplerModelId": {
            "type": "string",
            "minLength": 1
          },
          "defaultTjsModelId": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "defaultKernelPath": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "modelBaseDir": {
            "type": ["string", "null"],
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
