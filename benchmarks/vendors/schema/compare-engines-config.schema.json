{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compare Engines Config",
  "type": "object",
  "required": ["schemaVersion", "modelProfiles"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updated": {
      "type": "string"
    },
    "formatMatrix": {
      "type": "object",
      "properties": {
        "doppler": {
          "type": "array",
          "items": { "type": "string", "enum": ["rdrr", "safetensors"] }
        },
        "transformersjs": {
          "type": "array",
          "items": { "type": "string", "enum": ["onnx", "safetensors"] }
        }
      },
      "additionalProperties": false
    },
    "modelProfiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dopplerModelId"],
        "properties": {
          "dopplerModelId": {
            "type": "string",
            "minLength": 1
          },
          "defaultTjsModelId": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "defaultDopplerSource": {
            "type": ["string", "null"],
            "enum": ["local", "quickstart-registry", null]
          },
          "modelBaseDir": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "defaultDopplerSurface": {
            "type": ["string", "null"],
            "enum": ["auto", "node", "browser", null]
          },
          "defaultUseChatTemplate": {
            "type": ["boolean", "null"]
          },
          "defaultDopplerFormat": {
            "type": ["string", "null"],
            "enum": ["rdrr", "safetensors", null]
          },
          "defaultTjsFormat": {
            "type": ["string", "null"],
            "enum": ["onnx", "safetensors", null]
          },
          "safetensorsSourceId": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "compareLane": {
            "type": ["string", "null"],
            "enum": ["performance_comparable", "capability_only", null]
          },
          "compareLaneReason": {
            "type": ["string", "null"],
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
