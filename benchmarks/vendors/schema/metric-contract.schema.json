{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compare Metric Contract",
  "type": "object",
  "required": ["schemaVersion", "metrics"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updated": {
      "type": "string"
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "unit", "higherBetter"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "higherBetter": {
            "type": "boolean"
          },
          "required": {
            "type": "boolean"
          },
          "derived": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": [
                "numeratorPaths",
                "denominatorPaths"
              ],
              "properties": {
                "numeratorPaths": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "denominatorPaths": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "minProperties": 0
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
