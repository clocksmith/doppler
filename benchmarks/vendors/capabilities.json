{
  "schemaVersion": 1,
  "updated": "2026-02-25",
  "featureCatalog": {
    "bench": [
      {
        "id": "browser_webgpu",
        "description": "Runs inference on WebGPU in browser."
      },
      {
        "id": "node_webgpu",
        "description": "Runs inference on WebGPU directly in Node runtime."
      },
      {
        "id": "headless_browser_harness",
        "description": "Has a maintained headless browser benchmark harness in this repo."
      },
      {
        "id": "standardized_workloads",
        "description": "Maps benchmark runs to shared workload IDs."
      },
      {
        "id": "cache_mode_control",
        "description": "Can force warm/cold cache behavior for repeated benchmark runs."
      },
      {
        "id": "decodeTokensPerSec",
        "description": "Reports decode throughput metric."
      },
      {
        "id": "prefillTokensPerSec",
        "description": "Reports prefill throughput metric."
      },
      {
        "id": "firstTokenMs",
        "description": "Reports time-to-first-token metric."
      },
      {
        "id": "modelLoadMs",
        "description": "Reports model load latency metric."
      },
      {
        "id": "firstResponseMs",
        "description": "Reports model-load plus first-token latency."
      },
      {
        "id": "prefillMs",
        "description": "Reports prefill wall-clock latency."
      },
      {
        "id": "decodeMs",
        "description": "Reports decode-only wall-clock latency."
      },
      {
        "id": "totalRunMs",
        "description": "Reports total run wall-clock latency."
      },
      {
        "id": "decodeMsPerTokenP50",
        "description": "Reports 50th percentile decode token latency."
      },
      {
        "id": "decodeMsPerTokenP95",
        "description": "Reports 95th percentile decode token latency."
      },
      {
        "id": "decodeMsPerTokenP99",
        "description": "Reports 99th percentile decode token latency."
      },
      {
        "id": "js_heap_memory_metrics",
        "description": "Reports JS heap memory metrics."
      },
      {
        "id": "gpu_memory_metrics",
        "description": "Reports GPU memory metrics."
      }
    ],
    "profile": [
      {
        "id": "kernel_level_gpu_timing",
        "description": "Provides kernel-level GPU timing breakdown."
      },
      {
        "id": "operator_level_timing",
        "description": "Provides model operator-level timing breakdown."
      },
      {
        "id": "top_ops_summary",
        "description": "Provides sorted top-op summary in benchmark output."
      },
      {
        "id": "per_decode_step_breakdown",
        "description": "Provides per-decode-step profiling breakdown."
      },
      {
        "id": "kernel_selection_trace",
        "description": "Provides selected kernel path/variant trace data."
      },
      {
        "id": "phase_memory_breakdown",
        "description": "Provides per-phase memory telemetry."
      },
      {
        "id": "cache_events",
        "description": "Provides cache hit/miss behavior telemetry."
      },
      {
        "id": "replayable_trace_artifact",
        "description": "Produces replayable trace artifact suitable for deterministic replay."
      }
    ]
  },
