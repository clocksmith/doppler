{
  "schemaVersion": 1,
  "updated": "2026-03-08",
  "timeoutsMs": {
    "compare": 600000,
    "doppler": 600000,
    "transformersjs": 600000
  },
  "requiredTimingFields": [
    "decodeTokensPerSec",
    "prefillTokensPerSec",
    "firstTokenMs",
    "firstResponseMs",
    "prefillMs",
    "decodeMs",
    "decodeMsPerTokenP50",
    "decodeMsPerTokenP95",
    "decodeMsPerTokenP99",
    "totalRunMs",
    "modelLoadMs"
  ],
  "requiredCompareMetricIds": [
    "decodeTokensPerSec",
    "promptTokensPerSecToFirstToken",
    "firstTokenMs",
    "firstResponseMs",
    "decodeMs",
    "decodeMsPerTokenP50",
    "decodeMsPerTokenP95",
    "decodeMsPerTokenP99",
    "totalRunMs",
    "modelLoadMs"
  ],
  "decodeProfiles": {
    "default": "parity",
    "presets": {
      "parity": {
        "batchSize": 1,
        "readbackInterval": 1,
        "stopCheckMode": "per-token",
        "label": "TJS-like per-token cadence"
      },
      "throughput": {
        "batchSize": 4,
        "readbackInterval": 4,
        "stopCheckMode": "per-token",
        "label": "Doppler throughput-tuned cadence"
      }
    }
  },
  "browser": {
    "stableArgs": [
      "--disable-breakpad",
      "--disable-gpu-sandbox",
      "--no-sandbox"
    ],
    "webgpuArgs": [
      "--enable-unsafe-webgpu",
      "--enable-webgpu-developer-features",
      "--disable-dawn-features=disallow_unsafe_apis",
      "--ignore-gpu-blocklist"
    ],
    "platformArgs": {
      "darwin": [
        "--use-angle=metal"
      ],
      "linux": [
        "--use-angle=vulkan",
        "--enable-features=Vulkan",
        "--disable-vulkan-surface"
      ],
      "win32": []
    }
  },
  "kernelPathPolicy": {
    "knownBadByModel": {
      "gemma-3-270m-it-f16-af32": [
        "gemma3-f16-fused-f16a-online"
      ]
    }
  }
}
