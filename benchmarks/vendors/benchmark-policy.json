{
  "schemaVersion": 1,
  "updated": "2026-03-29",
  "timeoutsMs": {
    "compare": 600000,
    "doppler": 600000,
    "doppler-simulatte": 600000,
    "doppler-webgpu-npm": 600000,
    "doppler-bun": 600000,
    "doppler-deno": 600000,
    "transformersjs": 600000,
    "transformersjs-simulatte": 600000,
    "transformersjs-webgpu-npm": 600000,
    "transformersjs-bun": 600000,
    "transformersjs-deno": 600000
  },
  "requiredTimingFields": [
    "decodeTokensPerSec",
    "prefillTokensPerSec",
    "firstTokenMs",
    "firstResponseMs",
    "prefillMs",
    "decodeMs",
    "decodeMsPerTokenP50",
    "decodeMsPerTokenP95",
    "decodeMsPerTokenP99",
    "totalRunMs",
    "modelLoadMs"
  ],
  "requiredCompareMetricIds": [
    "decodeTokensPerSec",
    "promptTokensPerSecToFirstToken",
    "firstTokenMs",
    "firstResponseMs",
    "decodeMs",
    "decodeMsPerTokenP50",
    "decodeMsPerTokenP95",
    "decodeMsPerTokenP99",
    "totalRunMs",
    "modelLoadMs"
  ],
  "decodeProfiles": {
    "default": "parity",
    "profiles": {
      "parity": {
        "batchSize": 4,
        "readbackInterval": 4,
        "disableMultiTokenDecode": false,
        "speculationMode": "none",
        "stopCheckMode": "batch",
        "label": "Doppler release decode cadence"
      },
      "throughput": {
        "batchSize": 4,
        "readbackInterval": 4,
        "disableMultiTokenDecode": false,
        "speculationMode": "none",
        "stopCheckMode": "batch",
        "label": "Doppler throughput-tuned cadence"
      }
    }
  },
  "browser": {
    "compareChannelByPlatform": {
      "darwin": "chromium",
      "linux": "chromium",
      "win32": "chromium"
    },
    "stableArgs": [
      "--disable-breakpad",
      "--disable-gpu-sandbox",
      "--no-sandbox"
    ],
    "webgpuArgs": [
      "--enable-unsafe-webgpu",
      "--enable-webgpu-developer-features",
      "--disable-dawn-features=disallow_unsafe_apis",
      "--ignore-gpu-blocklist"
    ],
    "platformArgs": {
      "darwin": [
        "--use-angle=metal"
      ],
      "linux": [
        "--use-angle=vulkan",
        "--enable-features=Vulkan",
        "--disable-vulkan-surface"
      ],
      "win32": []
    }
  },
  "kernelPathPolicy": {
    "compareRuntime": {
      "mode": "capability-aware",
      "sourceScope": [
        "model",
        "manifest",
        "config"
      ],
      "allowSources": [
        "model",
        "manifest",
        "config"
      ],
      "onIncompatible": "remap"
    },
    "knownBadByModel": {
      "gemma-3-270m-it-f16-af32": [
        "gemma3-f16-fused-f16a-online"
      ]
    }
  },
  "doppler": {
    "loadModeRuntimeOverlays": {
      "http": {
        "description": "Cold HTTP compare runs use direct range reads, skip eager full-shard hash verification, coalesce ranges into shard-sized blocks, and opt RDRR manifests into bounded whole-shard prefetch; manifest preflight and pinned hosted revisions remain recorded in the compare artifact.",
        "runtimeConfig": {
          "loading": {
            "distribution": {
              "sourceOrder": [
                "http"
              ]
            },
            "shardCache": {
              "verifyHashes": false,
              "rangeCacheBlockBytes": 67108864,
              "rangeCacheMaxBytes": 536870912,
              "rangeCacheMinBytes": 4096,
              "maxConcurrentLoads": 8
            },
            "prefetch": {
              "allowRangeLoaderPrefetch": true,
              "layersAhead": 1,
              "maxShards": 8
            }
          }
        }
      }
    }
  }
}
