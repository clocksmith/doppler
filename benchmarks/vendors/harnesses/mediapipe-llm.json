{
  "schemaVersion": 1,
  "id": "mediapipe-llm",
  "name": "MediaPipe LLM Harness",
  "execution": {
    "mode": "external-command",
    "stdoutFormat": "json",
    "defaultCommand": null,
    "examples": [
      "node external/mediapipe-llm-bench.js --workload decode-64-128-greedy --json"
    ]
  },
  "normalization": {
    "metricPaths": {
      "decodeTokensPerSec": ["metrics.decodeTokensPerSec"],
      "prefillTokensPerSec": ["metrics.prefillTokensPerSec"],
      "firstTokenMs": ["metrics.firstTokenMs"],
      "decodeMsPerTokenP50": ["metrics.decodeMsPerTokenP50"],
      "decodeMsPerTokenP95": ["metrics.decodeMsPerTokenP95"],
      "peak_memory_mb": ["metrics.peak_memory_mb"]
    },
    "metadataPaths": {
      "version": ["env.version"],
      "model": ["model.id"]
    },
    "requiredMetrics": [
      "decodeTokensPerSec",
      "firstTokenMs"
    ]
  }
}
