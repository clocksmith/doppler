{
  "schemaVersion": 1,
  "id": "webllm",
  "name": "WebLLM Harness",
  "execution": {
    "mode": "external-command",
    "stdoutFormat": "json",
    "defaultCommand": null,
    "examples": [
      "node tools/vendor-bench.js import --target webllm --input /tmp/webllm-result.json",
      "node tools/vendor-bench.js run --target webllm --workload p064-d064-t0-k1 -- node ./path/to/webllm-runner.js --json"
    ]
  },
  "normalization": {
    "metricPaths": {
      "decodeTokensPerSec": ["metrics.decodeTokensPerSec"],
      "prefillTokensPerSec": ["metrics.prefillTokensPerSec"],
      "firstTokenMs": ["metrics.firstTokenMs"],
      "decodeMsPerTokenP50": ["metrics.decodeMsPerTokenP50"],
      "decodeMsPerTokenP95": ["metrics.decodeMsPerTokenP95"],
      "peak_memory_mb": ["metrics.peak_memory_mb"]
    },
    "metadataPaths": {
      "version": ["env.version"],
      "model": ["model.id"],
      "browser": ["env.browser"]
    },
    "requiredMetrics": [
      "decodeTokensPerSec",
      "prefillTokensPerSec",
      "firstTokenMs"
    ]
  }
}
