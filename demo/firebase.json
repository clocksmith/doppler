{
  "hosting": {
    "public": "..",
    "headers": [
      {
        "source": "/models/catalog.json",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate, max-age=0"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/", "destination": "/demo/index.html" }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "NOTICE",
      "SECURITY.md",
      "**/.*",
      "**/.*/**",
      ".github/**",
      "**/node_modules/**",
      "examples/**",
      "lean/**",
      "**/*.d.ts",
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md",
      "EMOJI.md",
      "docs/**",
      "tests/**",
      "bench/**",
      "tools/**/*.js",
      "tools/**/*.mjs",
      "tools/**/*.cjs",
      "tools/**/*.ts",
      "tools/**/*.sh",
      "test-results/**",
      "kernel-tests/**",
      "playwright-report/**",
      "benchmarks/**/*.js",
      "benchmarks/**/*.mjs",
      "benchmarks/**/*.cjs",
      "benchmarks/**/*.ts",
      "benchmarks/**/*.md",
      "benchmarks/**/*.html",
      "benchmarks/**/*.py",
      "benchmarks/**/*.json",
      "benchmarks/out/**",
      "benchmarks/vendors/results/**",
      "!benchmarks/vendors/compare-engines.config.json",
      "artifacts/**",
      "external/**",
      "skills/**",
      "package.json",
      "package-lock.json",
      "tsconfig.json",
      "tsconfig.build.json",
      "firebase-debug.log",
      ".tjs-bench-profile/**",
      ".cache/**",
      ".tmp/**",
      ".test-cache/**",
      ".benchmark-cache/**",
      ".headless-test-cache/**",
      ".headed-test-cache/**",
      ".pw-home/**",
      "tmp/**",
      "bench-results/**",
      "benchmark_*.json",
      "compare_*.json",
      "models/fixtures/**",
      "demo/fixtures/**",
      "reports/**",
      "models/curated/**",
      "models/local/**",
      "models/converted/**"
    ]
  }
}
