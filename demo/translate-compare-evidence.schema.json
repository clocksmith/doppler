{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://simulatte.world/schemas/doppler/translate-compare-evidence.schema.json",
  "title": "Doppler Translate Compare Evidence Bundle",
  "description": "Evidence payload consumed by the Doppler demo translate compare console.",
  "type": "object",
  "required": ["summary", "caution", "teacher", "student", "receipts"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "updatedAt": {
      "type": ["string", "null"],
      "description": "ISO-8601 timestamp or short frozen-bundle label shown in the UI."
    },
    "summary": {
      "type": "string"
    },
    "caution": {
      "type": "string"
    },
    "teacher": {
      "$ref": "#/$defs/modelEvidence"
    },
    "student": {
      "$ref": "#/$defs/modelEvidence"
    },
    "receipts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/receipt"
      }
    }
  },
  "$defs": {
    "metricValue": {
      "type": ["number", "null"]
    },
    "modelEvidence": {
      "type": "object",
      "required": ["label", "modelId", "bleu", "chrf", "sizeBytes"],
      "properties": {
        "label": {
          "type": "string"
        },
        "modelId": {
          "type": ["string", "null"]
        },
        "bleu": {
          "$ref": "#/$defs/metricValue"
        },
        "chrf": {
          "$ref": "#/$defs/metricValue"
        },
        "sizeBytes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "receipt": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string"
        }
      },
      "required": [],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
